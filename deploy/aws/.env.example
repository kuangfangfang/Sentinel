# Copy to deploy/aws/.env — never commit .env
#
# Generate a signing key (PowerShell):
#   [Convert]::ToBase64String((1..64 | ForEach-Object { Get-Random -Maximum 256 }))
#
# Generate a strong caseworker password (PowerShell):
#   -join ((48..57 + 65..90 + 97..122) | Get-Random -Count 24 | ForEach-Object { [char]$_ })

JWT_SIGNING_KEY=replace-with-a-long-random-secret-at-least-32-characters
FRONTEND_ORIGIN=https://your-frontend.example.com
VITE_API_BASE_URL=https://api.your-domain.com/api

# First caseworker account — created once on API startup if it does not exist.
SEED_BOOTSTRAP_CASEWORKER_EMAIL=admin@your-domain.example
SEED_BOOTSTRAP_CASEWORKER_PASSWORD=replace-with-a-strong-password
SEED_BOOTSTRAP_CASEWORKER_FULL_NAME=Sentinel Admin
