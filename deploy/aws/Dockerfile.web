# Sentinel SPA — static nginx image (optional if not using Amplify Hosting).
# Build from repo root:
#   docker build -f deploy/aws/Dockerfile.web --build-arg VITE_API_BASE_URL=https://api.example.com/api -t sentinel-web .

FROM node:22-alpine AS build
WORKDIR /app
COPY sentinel-web/package.json sentinel-web/package-lock.json ./
RUN npm ci
COPY sentinel-web/ .
ARG VITE_API_BASE_URL=http://localhost:5187/api
ARG VITE_SITE_URL=http://localhost:5173
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_SITE_URL=$VITE_SITE_URL
RUN npm run build

FROM nginx:1.27-alpine
COPY deploy/aws/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
