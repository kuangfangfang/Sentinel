{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "DatabaseProvider": "Sqlite",
  "ConnectionStrings": {
    "Sqlite": "Data Source=sentinel.db",
    "SqlServer": ""
  },
  "Jwt": {
    "Issuer": "Sentinel.Api",
    "Audience": "Sentinel.Web",
    "ExpiryMinutes": 120,
    "SigningKey": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:5174",
      "http://localhost:5175",
      "http://localhost:4173",
      "http://127.0.0.1:5173",
      "http://127.0.0.1:5174",
      "http://127.0.0.1:5175",
      "http://127.0.0.1:4173"
    ]
  },
  "FileStorage": {
    "Root": "App_Data/uploaded-evidence",
    "MaxFileBytes": 10485760,
    "MaxFilesPerComplaint": 10
  },
  "QuickExit": {
    "DestinationUrl": "https://www.bom.gov.au"
  },
  "AbrLookup": {
    "Guid": ""
  }
}
